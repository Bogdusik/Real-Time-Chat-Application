# PostgreSQL (Node.js server)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatdb
DB_USER=chatuser
DB_PASSWORD=your-secure-password-here

# PostgreSQL (Spring Boot backend)
# These map to application.properties placeholders
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatdb
DB_USER=chatuser
DB_PASSWORD=your-secure-password-here
JPA_DDL_AUTO=validate

# Server
PORT=8080
CORS_ORIGIN=http://localhost:3000

# Spring Security (change in production!)
SPRING_SECURITY_USER=admin
SPRING_SECURITY_PASSWORD=your-secure-admin-password-here

# HTTPS (optional, leave empty for HTTP in dev)
# SSL_KEY_PATH=/path/to/server.key
# SSL_CERT_PATH=/path/to/server.crt

# Frontend (React)
REACT_APP_API_URL=http://localhost:8080
